# ---- Anthropic (answer generation) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI (embeddings only — Claude has no embeddings endpoint) ----
OPENAI_API_KEY=sk-...

# ---- Supabase ----
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon/publishable key (safe to expose to the browser; used by the chat API route on the server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — REQUIRED ONLY for the ingest script (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Optional model overrides ----
# Embeddings: OpenAI
EMBEDDING_MODEL=text-embedding-3-small
# Chat: Claude (haiku = fast/cheap, sonnet = higher quality)
CHAT_MODEL=claude-haiku-4-5-20251001
